{
    "name": "industrialdev/wicket-wp-account-centre",
    "description": "Wicket's Account Centre for WordPress",
    "version": "1.7.12",
    "extra": {},
    "homepage": "https://wicket.io",
    "keywords": [
        "wordpress",
        "wicket",
        "account",
        "centre"
    ],
    "license": "GPL-2.0-or-later",
    "type": "wordpress-plugin",
    "authors": [
        {
            "homepage": "https://wicket.io",
            "name": "Wicket Inc."
        }
    ],
    "autoload": {
        "psr-4": {
            "WicketAcc\\": "src/",
            "WicketORM\\": "src/WicketORM/"
        },
        "files": [
            "src/WicketORM/compat.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "automattic/jetpack-autoloader": true
        }
    },
    "repositories": [
        {
            "no-api": true,
            "type": "vcs",
            "url": "git@github.com:industrialdev/wicket-sdk-php.git"
        }
    ],
    "require": {
        "estebanforge/hyperblocks": "^1",
        "industrialdev/wicket-sdk-php": "dev-master",
        "php": ">=8.2.0",
        "picocss/pico": "^2.1",
        "starfederation/datastar-php": "^1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3"
    },
    "scripts": {
        "build-pico-css": "@php ./.ci/build-pico-css.php",
        "check": [
            "@cs:lint"
        ],
        "cs:fix": "php-cs-fixer fix",
        "cs:format": "php-cs-fixer fix",
        "cs:lint": "php-cs-fixer fix --dry-run --diff",
        "post-autoload-dump": [
            "@build-pico-css"
        ],
        "production": "composer install --no-scripts && composer cs:fix && composer install --no-dev --optimize-autoloader",
        "setup-hooks": "mkdir -p .git/hooks && cp .ci/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push && echo 'Git hooks installed to .git/hooks/pre-push'",
        "version-bump": "@php ./.ci/version-bump.php"
    }
}
